# Configuration du crawler
START_URL=https://www.cnrs.fr/fr/
MAX_PAGES=20
MAX_WORKERS=8
REQUEST_TIMEOUT=10
SCROLL_DELAY=5
RESOURCE_TIMEOUT=3

# Configuration Selenium
HEADLESS=true
CHROME_BINARY_PATH="C:\Program Files\Google\Chrome\Application\chrome.exe"
# Exemple Linux: CHROME_BINARY_PATH=/usr/bin/google-chrome

# Logging
LOG_LEVEL=INFO
LOG_FILE=outputs/crawler.log