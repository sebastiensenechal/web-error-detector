# Configuration du crawler
START_URL=https://www.lorem.fr/
MAX_PAGES=20
MAX_WORKERS=8
MAX_DEPTH=3
REQUEST_TIMEOUT=10

# Activer l'authentification Basic Auth (true/false)
BASIC_AUTH_ENABLED=false

# Identifiant pour l'authentification Basic Auth
BASIC_AUTH_USERNAME=

# Mot de passe pour l'authentification Basic Auth
BASIC_AUTH_PASSWORD=

# Configuration Selenium
HEADLESS=true
SCROLL_DELAY=5
RESOURCE_TIMEOUT=3
CHROME_BINARY_PATH=
# Exemple Windows: CHROME_BINARY_PATH="C:\Program Files\Google\Chrome\Application\chrome.exe"
# Exemple Linux: CHROME_BINARY_PATH=/usr/bin/google-chrome

# Logging
LOG_LEVEL=INFO
LOG_FILE=outputs/crawler.log